<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Assessment"
             xmlns:converters="clr-namespace:Assessment.Converters"
             x:Class="Assessment.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToShakeColorConverter x:Key="BoolToShakeColorConverter" />
            <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:BoolToLocationTextConverter x:Key="BoolToLocationTextConverter" />
            <converters:RatingToColorConverter x:Key="RatingToColorConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:DishImageConverter x:Key="DishImageConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
