<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             x:Class="Assessment.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <Frame Padding="15" CornerRadius="12" HasShadow="True" 
                   BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="12">
                    <Label Text="🎨 Appearance" FontSize="18" FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="{Binding ThemeIcon, StringFormat='{0} Theme'}" 
                                   FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding ThemeText}" FontSize="13" 
                                   TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}"
                                OnColor="{StaticResource Primary}"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <Label Text="💡 Tip: Theme changes take effect immediately and are saved automatically" 
                           FontSize="12" TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="15" CornerRadius="12" HasShadow="True" 
                   BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="12">
                    <Label Text="ℹ️ About" FontSize="18" FontAttributes="Bold" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15" Padding="0,5">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="App Info" FontSize="15" />
                            <Label Text="View version and features" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="View" FontSize="13"
                                CornerRadius="6" Padding="12,6"
                                Command="{Binding ShowAboutCommand}"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15" Padding="0,5">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Reset Data" FontSize="15" />
                            <Label Text="Clear cart and review records" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Reset" FontSize="13"
                                BackgroundColor="#FF5252" CornerRadius="6" Padding="12,6"
                                Command="{Binding ResetDataCommand}"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="15" CornerRadius="12" HasShadow="True" 
                   BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📋 Features" FontSize="18" FontAttributes="Bold" />

                    <Label FontSize="13" TextColor="{StaticResource Gray600}">
                        <Label.Text><![CDATA[
🍽️ Order - Browse dishes, add to cart, confirm orders

⭐ Reviews - Rate dishes, upload photos

🚚 Delivery - Get location, enter address, place delivery order

⚙️ Settings - Toggle dark/light mode, reset data]]></Label.Text>
                    </Label>
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="20" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
