<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             xmlns:models="clr-namespace:Assessment.Models"
             x:Class="Assessment.Views.DishListPage"
             x:DataType="vm:DishListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="0">

        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="15,10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <Label Text="🍽️ Mei Wei Xuan" FontSize="20" FontAttributes="Bold" 
                       TextColor="White" VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                    <Frame Padding="8,4" CornerRadius="15" HasShadow="False"
                           BackgroundColor="{Binding ShakeDetectionOn, Converter={StaticResource BoolToShakeColorConverter}}"
                           BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleShakeCommand}" />
                        </Frame.GestureRecognizers>
                        <Label Text="{Binding ShakeStatusText}" FontSize="12" TextColor="White" />
                    </Frame>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                    <Label Text="🛒" FontSize="24" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToCartCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Frame BackgroundColor="#FF6B6B" CornerRadius="10" Padding="6,2"
                           IsVisible="{Binding CartItemCount, Converter={StaticResource IntToBoolConverter}}"
                           HasShadow="False" BorderColor="Transparent">
                        <Label Text="{Binding CartItemCount}" FontSize="12" TextColor="White" />
                    </Frame>
                </HorizontalStackLayout>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1" Orientation="Horizontal" BackgroundColor="White" 
                    Padding="10,5" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="8"
                                    BindableLayout.ItemsSource="{Binding Categories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Frame Padding="12,6" CornerRadius="16" HasShadow="False"
                               BorderColor="{StaticResource Primary}" BackgroundColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DishListViewModel}}, Path=FilterByCategoryCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Label Text="{Binding .}" FontSize="13" 
                                   TextColor="{StaticResource Primary}" />
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <Label Grid.Row="1" IsVisible="False" />

        <RefreshView Grid.Row="2"
                      IsRefreshing="{Binding IsRefreshing}"
                      Command="{Binding RefreshCommand}"
                      RefreshColor="{StaticResource Primary}">
            <CollectionView ItemsSource="{Binding Dishes}"
                             SelectionMode="None"
                             Margin="10"
                             RemainingItemsThreshold="2"
                             RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                    <Label Text="😕" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="No dishes available" FontSize="16" TextColor="{StaticResource Gray400}" 
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.Footer>
                <VerticalStackLayout Padding="0,10,0,20" HorizontalOptions="Center" Spacing="6">
                    <ActivityIndicator IsRunning="{Binding IsLoadingMore}" 
                                       IsVisible="{Binding IsLoadingMore}"
                                       Color="{StaticResource Primary}" 
                                       HeightRequest="24" />
                    <Label Text="🍽️ Loading more dishes..."
                           FontSize="13" TextColor="{StaticResource Gray400}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasMoreItems}" />
                    <Label Text="— End of list —"
                           FontSize="12" TextColor="{StaticResource Gray300}"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" 
                                         Binding="{Binding HasMoreItems}" Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </CollectionView.Footer>
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" 
                                  VerticalItemSpacing="10" HorizontalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Dish">
                    <Frame Padding="10" CornerRadius="12" HasShadow="True" 
                           BorderColor="Transparent" BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DishListViewModel}}, Path=NavigateToDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Frame CornerRadius="8" Padding="0" HeightRequest="140" 
                                       BackgroundColor="{StaticResource Gray100}"
                                       HasShadow="False" BorderColor="Transparent"
                                       IsClippedToBounds="True">
                                <Image Source="{Binding ImageName, Converter={StaticResource DishImageConverter}}" 
                                       Aspect="AspectFit"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center" />
                            </Frame>
                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" 
                                   LineBreakMode="TailTruncation" MaxLines="1" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Price, StringFormat='¥{0:F2}'}" 
                                       FontSize="14" TextColor="#FF6B6B" FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Frame Grid.Column="1" BackgroundColor="{StaticResource Primary}" 
                                       CornerRadius="6" Padding="4,2" HasShadow="False"
                                       BorderColor="Transparent">
                                    <Label Text="{Binding Rating, StringFormat='{0:F1}★'}" 
                                           FontSize="11" TextColor="White" />
                                </Frame>
                            </Grid>
                            <Button Text="➕ Add to Cart" FontSize="11" HeightRequest="32"
                                    CornerRadius="6" Padding="6,2"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DishListViewModel}}, Path=AddToCartCommand}"
                                    CommandParameter="{Binding .}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="2" IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           VerticalOptions="Center" HorizontalOptions="Center"
                           Color="{StaticResource Primary}" />

        <Frame Grid.Row="3" IsVisible="{Binding HasError}" 
               BackgroundColor="#FFF3CD" Padding="10" CornerRadius="0"
               HasShadow="False" BorderColor="#FFC107">
            <Label Text="{Binding ErrorMessage}" TextColor="#856404" FontSize="13"
                   HorizontalOptions="Center" />
        </Frame>
    </Grid>
</ContentPage>
