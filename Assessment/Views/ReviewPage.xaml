<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             xmlns:models="clr-namespace:Assessment.Models"
             x:Class="Assessment.Views.ReviewPage"
             x:DataType="vm:ReviewViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="15,10">
            <Label Text="⭐ Reviews" FontSize="20" FontAttributes="Bold" 
                   TextColor="White" HorizontalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="15">
            <VerticalStackLayout Spacing="15">

                <Label Text="Write a Review" FontSize="18" FontAttributes="Bold" />

                <Label Text="Select Dish" FontSize="14" FontAttributes="Bold" />
                <Picker Title="Select a dish to review"
                        ItemsSource="{Binding Dishes}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedIndex="{Binding SelectedDishIndex}"
                        SelectedItem="{Binding SelectedDish}"
                        FontSize="14" />

                <Label Text="Rating" FontSize="14" FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="8">
                    <Button Text="1★" FontSize="12" WidthRequest="50" HeightRequest="36"
                            CornerRadius="6" Padding="0"
                            BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=1}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReviewViewModel}}, Path=SetRatingCommand}"
                            CommandParameter="1" />
                    <Button Text="2★" FontSize="12" WidthRequest="50" HeightRequest="36"
                            CornerRadius="6" Padding="0"
                            BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=2}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReviewViewModel}}, Path=SetRatingCommand}"
                            CommandParameter="2" />
                    <Button Text="3★" FontSize="12" WidthRequest="50" HeightRequest="36"
                            CornerRadius="6" Padding="0"
                            BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=3}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReviewViewModel}}, Path=SetRatingCommand}"
                            CommandParameter="3" />
                    <Button Text="4★" FontSize="12" WidthRequest="50" HeightRequest="36"
                            CornerRadius="6" Padding="0"
                            BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=4}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReviewViewModel}}, Path=SetRatingCommand}"
                            CommandParameter="4" />
                    <Button Text="5★" FontSize="12" WidthRequest="50" HeightRequest="36"
                            CornerRadius="6" Padding="0"
                            BackgroundColor="{Binding Rating, Converter={StaticResource RatingToColorConverter}, ConverterParameter=5}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ReviewViewModel}}, Path=SetRatingCommand}"
                            CommandParameter="5" />
                </HorizontalStackLayout>

                <Label Text="Your Review" FontSize="14" FontAttributes="Bold" />
                <Editor Text="{Binding CommentText}" 
                        Placeholder="Enter your review..." 
                        HeightRequest="100"
                        FontSize="14" />

                <Button Text="{Binding PhotoButtonText}" FontSize="14"
                        BackgroundColor="#2196F3" CornerRadius="8"
                        Command="{Binding TakePhotoCommand}"
                        HorizontalOptions="Fill" />

                <Frame IsVisible="{Binding HasPhoto}" CornerRadius="8" Padding="8"
                       HasShadow="False" BorderColor="{StaticResource Gray200}">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                        <Image Source="{Binding PhotoPath}" HeightRequest="160" Aspect="AspectFit" />
                        <Label Grid.Row="1" Text="✅ Photo captured" FontSize="12" 
                               TextColor="#4CAF50" HorizontalOptions="Center" />
                    </Grid>
                </Frame>

                <Button Text="Submit Review" FontSize="16" FontAttributes="Bold"
                        BackgroundColor="#FF6B6B" CornerRadius="10"
                        Command="{Binding SubmitReviewCommand}"
                        HorizontalOptions="Fill" HeightRequest="48" />

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,10" />

                <Label Text="Review History" FontSize="18" FontAttributes="Bold" />

                <CollectionView ItemsSource="{Binding Reviews}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No reviews yet" FontSize="14" 
                               TextColor="{StaticResource Gray400}" 
                               HorizontalOptions="Center" Margin="0,20" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Review">
                            <Frame Margin="0,5" Padding="12" CornerRadius="10" HasShadow="True"
                                   BorderColor="Transparent" BackgroundColor="White">
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding DishName}" FontSize="15" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding ReviewDate, StringFormat='{0:yyyy-MM-dd HH:mm}'}" 
                                               FontSize="11" TextColor="{StaticResource Gray400}" />
                                    </Grid>
                                    <HorizontalStackLayout Spacing="2">
                                        <Label Text="★★★★★" FontSize="13" TextColor="#FFD700" 
                                               MaxLines="1" LineBreakMode="TailTruncation">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Rating}" Value="1">
                                                    <Setter Property="Text" Value="★☆☆☆☆" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Rating}" Value="2">
                                                    <Setter Property="Text" Value="★★☆☆☆" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Rating}" Value="3">
                                                    <Setter Property="Text" Value="★★★☆☆" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Rating}" Value="4">
                                                    <Setter Property="Text" Value="★★★★☆" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Comment}" FontSize="13" 
                                           TextColor="{StaticResource Gray600}" />
                                    <Image Source="{Binding PhotoPath}" HeightRequest="120" 
                                           Aspect="AspectFit" IsVisible="{Binding PhotoPath, Converter={StaticResource IsNotNullConverter}}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="2" IsVisible="{Binding HasError}" 
               BackgroundColor="#FFF3CD" Padding="10" CornerRadius="0"
               HasShadow="False" BorderColor="#FFC107">
            <Label Text="{Binding ErrorMessage}" TextColor="#856404" FontSize="13"
                   HorizontalOptions="Center" />
        </Frame>
    </Grid>
</ContentPage>