<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             x:Class="Assessment.Views.DishDetailPage"
             x:DataType="vm:DishDetailViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto,Auto" Padding="0">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12" Padding="15">

                <Frame x:Name="DetailImageFrame" CornerRadius="12" Padding="0" HasShadow="False" 
                       BorderColor="{StaticResource Gray200}" BackgroundColor="{StaticResource Gray100}"
                       HeightRequest="250">
                    <Frame.GestureRecognizers>
                        <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                    </Frame.GestureRecognizers>
                    <Image x:Name="DetailImage"
                           Source="{Binding Dish.ImageName, Converter={StaticResource DishImageConverter}}" 
                           Aspect="AspectFit"
                           Scale="{Binding CurrentScale}"
                           AnchorX="0.5" AnchorY="0.5">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenFullScreenImageCommand}" />
                        </Image.GestureRecognizers>
                    </Image>
                </Frame>

                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Button Text="🔍 -" FontSize="12" HeightRequest="32" WidthRequest="44"
                            CornerRadius="16" Padding="0"
                            Command="{Binding ZoomOutCommand}" />
                    <Button Text="↺" FontSize="14" HeightRequest="32" WidthRequest="44"
                            CornerRadius="16" Padding="0"
                            Command="{Binding ResetZoomCommand}" />
                    <Button Text="🔍 +" FontSize="12" HeightRequest="32" WidthRequest="44"
                            CornerRadius="16" Padding="0"
                            Command="{Binding ZoomInCommand}" />
                </HorizontalStackLayout>

                <Label Text="💡 Tip: Use pinch gesture on the image above to zoom in/out" 
                       FontSize="11" TextColor="{StaticResource Gray400}" 
                       HorizontalOptions="Center" />

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,5" />

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="{Binding Dish.Name}" FontSize="22" FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Frame Grid.Column="1" BackgroundColor="{StaticResource Primary}" 
                           CornerRadius="8" Padding="8,4" HasShadow="False" BorderColor="Transparent">
                        <Label Text="{Binding Dish.Rating, StringFormat='{0:F1} ★'}" 
                               FontSize="14" TextColor="White" FontAttributes="Bold" />
                    </Frame>
                </Grid>

                <Label Text="{Binding Dish.Price, StringFormat='¥{0:F2}'}" 
                       FontSize="24" TextColor="#FF6B6B" FontAttributes="Bold" />

                <HorizontalStackLayout Spacing="15">
                    <Frame BackgroundColor="#FFF3E0" CornerRadius="8" Padding="8,4" 
                           HasShadow="False" BorderColor="Transparent">
                        <Label FontSize="12" TextColor="#E65100">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0} | Prep ~{1}min">
                                    <Binding Path="Dish.Category" />
                                    <Binding Path="Dish.PrepTimeMinutes" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Frame>
                    <Frame BackgroundColor="{StaticResource Secondary}" CornerRadius="8" 
                           Padding="8,4" HasShadow="False" BorderColor="Transparent"
                           IsVisible="{Binding Dish.IsSpicy}">
                        <Label Text="🌶️ Spicy" FontSize="12" TextColor="{StaticResource Tertiary}" />
                    </Frame>
                    <Frame BackgroundColor="#E8F5E9" CornerRadius="8" Padding="8,4" 
                           HasShadow="False" BorderColor="Transparent"
                           IsVisible="{Binding Dish.IsVegetarian}">
                        <Label Text="🥬 Veg" FontSize="12" TextColor="#2E7D32" />
                    </Frame>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,5" />

                <Label Text="Description" FontSize="16" FontAttributes="Bold" />
                <Label Text="{Binding Dish.Description}" FontSize="14" 
                       TextColor="{StaticResource Gray600}" LineHeight="1.5" />

                <Button Text="{Binding SpeechButtonText}" 
                        FontSize="14" 
                        BackgroundColor="#4CAF50"
                        Command="{Binding SpeakDescriptionCommand}"
                        HorizontalOptions="Fill"
                        CornerRadius="8" />

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                <Label Text="Quantity" FontSize="16" FontAttributes="Bold" />
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                    <Button Text="-" FontSize="18" WidthRequest="44" HeightRequest="44"
                            CornerRadius="22" Padding="0"
                            Command="{Binding DecreaseQuantityCommand}" />
                    <Label Grid.Column="1" Text="{Binding Quantity}" FontSize="20" 
                           FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                    <Button Grid.Column="2" Text="+" FontSize="18" WidthRequest="44" HeightRequest="44"
                            CornerRadius="22" Padding="0"
                            Command="{Binding IncreaseQuantityCommand}" />
                </Grid>

                <BoxView HeightRequest="10" />
            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="1" IsVisible="{Binding HasError}" 
               BackgroundColor="#FFF3CD" Padding="10" CornerRadius="0"
               HasShadow="False" BorderColor="#FFC107">
            <Label Text="{Binding ErrorMessage}" TextColor="#856404" FontSize="13"
                   HorizontalOptions="Center" />
        </Frame>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="15,10"
              BackgroundColor="White">
            <Button Text="← Back" 
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="{StaticResource Gray400}"
                    CornerRadius="8" />
            <Button Grid.Column="1" Text="Add to Cart"
                    Command="{Binding AddToCartCommand}"
                    BackgroundColor="#FF6B6B"
                    CornerRadius="8" FontAttributes="Bold" />
        </Grid>
    </Grid>
</ContentPage>