<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             x:Class="Assessment.Views.DeliveryPage"
             x:DataType="vm:DeliveryViewModel"
             Title="Delivery">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <Frame Padding="15" CornerRadius="12" HasShadow="True" 
                   BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📍 Delivery Address" FontSize="18" FontAttributes="Bold" />

                    <Button Text="{Binding IsBusy, Converter={StaticResource BoolToLocationTextConverter}}" 
                            FontSize="14" CornerRadius="8"
                            Command="{Binding GetLocationCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                    <Frame IsVisible="{Binding HasLocation}" 
                           BackgroundColor="#E8F5E9" CornerRadius="8" Padding="12"
                           HasShadow="False" BorderColor="#C8E6C9">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="✅ Location obtained" FontSize="13" FontAttributes="Bold" TextColor="#2E7D32" />
                            <Label Text="{Binding CurrentAddress}" FontSize="13" TextColor="#33691E" />
                            <Label FontSize="12" TextColor="#558B2F">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}Longitude: {0:F6}   Latitude: {1:F6}">
                                        <Binding Path="CurrentLongitude" />
                                        <Binding Path="CurrentLatitude" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="15" CornerRadius="12" HasShadow="True" 
                   BorderColor="Transparent" BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📝 Delivery Info" FontSize="18" FontAttributes="Bold" />

                    <Label Text="Address" FontSize="14" FontAttributes="Bold" />
                    <Entry Text="{Binding DeliveryAddress}" 
                           Placeholder="Enter detailed delivery address"
                           FontSize="14" ClearButtonVisibility="WhileEditing" />

                    <Label Text="Phone" FontSize="14" FontAttributes="Bold" />
                    <Entry Text="{Binding PhoneNumber}" 
                           Placeholder="Enter phone number"
                           Keyboard="Telephone" FontSize="14"
                           ClearButtonVisibility="WhileEditing" />

                    <Label Text="Note (optional)" FontSize="14" FontAttributes="Bold" />
                    <Editor Text="{Binding Note}" 
                            Placeholder="Special requests or notes..."
                            HeightRequest="80" FontSize="14" />
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="15" CornerRadius="12" HasShadow="True" 
                   BorderColor="Transparent" BackgroundColor="White"
                   IsVisible="{Binding HasItems}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="🛒 Order Summary" FontSize="18" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Items" FontSize="14" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Column="1" Text="{Binding ItemCount, StringFormat='{0} items'}" 
                               FontSize="14" FontAttributes="Bold" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total" FontSize="14" TextColor="{StaticResource Gray500}" />
                        <Label Grid.Column="1" Text="{Binding TotalPrice, StringFormat='¥{0:F2}'}" 
                               FontSize="18" FontAttributes="Bold" TextColor="#FF6B6B" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="15" CornerRadius="12" HasShadow="False" 
                   BorderColor="Transparent" BackgroundColor="#FFF3E0"
                   IsVisible="{Binding HasItems, Converter={StaticResource InvertBoolConverter}}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="🛒 Empty Cart" FontSize="16" FontAttributes="Bold" 
                           HorizontalOptions="Center" TextColor="#E65100" />
                    <Label Text="Please go to the menu page to add dishes" FontSize="13" 
                           HorizontalOptions="Center" TextColor="#BF360C" />
                    <Button Text="Go to Menu" FontSize="14"
                            BackgroundColor="#FF9800" CornerRadius="8"
                            Command="{Binding NavigateToMenuCommand}"
                            HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Place Delivery Order" FontSize="18" FontAttributes="Bold"
                    BackgroundColor="#4CAF50" CornerRadius="12" HeightRequest="50"
                    Command="{Binding SubmitDeliveryCommand}"
                    IsVisible="{Binding HasItems}"
                    HorizontalOptions="Fill" />

            <BoxView HeightRequest="20" Color="Transparent" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>