<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             x:Class="Assessment.Views.WelcomePage"
             x:DataType="vm:WelcomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Primary}">

    <Grid Padding="{OnIdiom Phone=30, Tablet=60}">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20"
                             MaximumWidthRequest="{OnIdiom Phone=9999, Tablet=520}">

            <Frame CornerRadius="{OnIdiom Phone=60, Tablet=80}"
                   WidthRequest="{OnIdiom Phone=120, Tablet=160}"
                   HeightRequest="{OnIdiom Phone=120, Tablet=160}"
                   BackgroundColor="White" Padding="0" HasShadow="False"
                   HorizontalOptions="Center" BorderColor="Transparent">
                <Label Text="🍽️"
                       FontSize="{OnIdiom Phone=56, Tablet=76}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>

            <Label Text="{Binding WelcomeText}"
                   FontSize="{OnIdiom Phone=32, Tablet=44}"
                   FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" />

            <Label Text="{Binding SubtitleText}"
                   FontSize="{OnIdiom Phone=16, Tablet=20}"
                   TextColor="#DFD8F7"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="30" Color="Transparent" />

            <ActivityIndicator IsRunning="True" Color="White"
                               HorizontalOptions="Center" />
            <Label Text="Loading..."
                   FontSize="{OnIdiom Phone=13, Tablet=16}"
                   TextColor="#DFD8F7"
                   HorizontalOptions="Center" />

            <Label Text="v1.0 · .NET MAUI"
                   FontSize="11" TextColor="#9880e5"
                   HorizontalOptions="Center" Margin="0,40,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>