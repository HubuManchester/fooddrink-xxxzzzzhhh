<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Assessment.ViewModels"
             x:Class="Assessment.Views.MapPage"
             x:DataType="vm:MapViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto,Auto" Padding="0">

        <WebView Grid.Row="0" x:Name="MapWebView" />

        <VerticalStackLayout Grid.Row="1" Padding="15,10" Spacing="8" BackgroundColor="White">

            <Grid ColumnDefinitions="*,Auto">
                <Label Text="📍 Mei Wei Xuan" FontSize="18" FontAttributes="Bold" 
                       VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Copy Coordinates" FontSize="12"
                        CornerRadius="6" Padding="10,4"
                        Command="{Binding CopyShopLocationCommand}" />
            </Grid>

            <Label FontSize="13" TextColor="{StaticResource Gray500}">
                <Label.Text>
                    <MultiBinding StringFormat="{}Longitude: {0:F6}   Latitude: {1:F6}">
                        <Binding Path="ShopLongitudeValue" />
                        <Binding Path="ShopLatitudeValue" />
                    </MultiBinding>
                </Label.Text>
            </Label>

            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

            <Button Text="{Binding IsBusy, Converter={StaticResource BoolToLocationTextConverter}}" 
                    FontSize="15" CornerRadius="8"
                    Command="{Binding GetCurrentLocationCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

            <Frame IsVisible="{Binding HasLocation}" 
                   BackgroundColor="#E8F5E9" CornerRadius="8" Padding="12"
                   HasShadow="False" BorderColor="#C8E6C9">
                <VerticalStackLayout Spacing="6">
                    <Label FontSize="14" FontAttributes="Bold" TextColor="#2E7D32">
                        <Label.Text>
                            <MultiBinding StringFormat="{}{0:N6}, {1:N6}">
                                <Binding Path="CurrentLatitude" />
                                <Binding Path="CurrentLongitude" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                    <Label Text="{Binding CurrentAddress}" FontSize="13" TextColor="#33691E" />
                    <Label Text="{Binding DistanceText}" FontSize="14" 
                           FontAttributes="Bold" TextColor="#FF6B6B" />
                    <Button Text="Copy My Location" FontSize="12"
                            BackgroundColor="#4CAF50" CornerRadius="6" Padding="10,4"
                            Command="{Binding CopyLocationCommand}" 
                            HorizontalOptions="Start" />
                </VerticalStackLayout>
            </Frame>

            <Frame IsVisible="{Binding LocationError}" 
                   BackgroundColor="#FFEBEE" CornerRadius="8" Padding="12"
                   HasShadow="False" BorderColor="#FFCDD2">
                <Label Text="{Binding LocationErrorMessage}" FontSize="13" TextColor="#C62828" />
            </Frame>

            <Label Text="💡 Map uses Amap data for China region" 
                   FontSize="11" TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Frame Grid.Row="2" IsVisible="{Binding HasError}" 
               BackgroundColor="#FFF3CD" Padding="10" CornerRadius="0"
               HasShadow="False" BorderColor="#FFC107">
            <Label Text="{Binding ErrorMessage}" TextColor="#856404" FontSize="13"
                   HorizontalOptions="Center" />
        </Frame>
    </Grid>
</ContentPage>